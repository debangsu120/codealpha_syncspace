{
  "name": "syncspace",
  "version": "1.0.0",
  "private": true,
  "description": "Real-time collaboration platform with video calls, whiteboard, chat, and file sharing",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build:prod",
    "start": "cd server && node server.js",
    "install:all": "cd server && npm install && cd ../frontend && npm install",
    "lint": "cd frontend && npm run lint",
    "typecheck": "cd frontend && npx tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
